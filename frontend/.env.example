# API Base URL за backend сървъра
# Ако не е зададено, се ползва '/api' (Vite proxy към localhost:8000)
# При build за production, задай тук реалния адрес на backend-а.
# Пример:
#   VITE_API_BASE_URL=http://192.168.1.100:8000
#
# Забележка: Това е build-time променлива. За runtime промяна
# използвай Настройки (⚙️) в UI-а — стойността се записва в localStorage.
VITE_API_BASE_URL=