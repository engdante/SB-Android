# Ollama host URL (local or cloud)
# Example: http://192.168.1.100:11434 or https://api.ollama.com
OLLAMA_HOST=https://api.ollama.com

# Backend URL (for frontend to connect)
BACKEND_URL=http://localhost:8000

# Ollama API key (optional, for cloud access)
OLLAMA_API_KEY=

# Cloud models (JSON array)
# Add new cloud models manually here
# Example: ["gemma4:cloud","qwen3.5:cloud"]
CLOUD_MODELS=[]

# Ingestion model (for saving and processing notes)
INGESTION_MODEL=

# RAG model (for answering questions based on stored knowledge)
RAG_MODEL=

# Audio transcription model (whisper.cpp GGUF model file)
AUDIO_MODEL=ggml-medium.en-q5_0.bin

# Debug system
DEBUG_ENABLED=true

# OKF data storage directory
OKF_DATA_DIR=./data

# Application metadata
APP_NAME=pi_sb
APP_VERSION=1.0.0

# Audio upload directory
AUDIO_UPLOAD_DIR=./data/audio

# Debug mode (controls uvicorn reload)
DEBUG=true